SEEDPAY_MID=
SEEDPAY_KEY=
SEEDPAY_BASE_URL=https://devpay.seedpayments.co.kr

# Supabase Shared Pooler 연결 문자열. 비밀번호에 특수문자가 있으면 percent-encoding 필요
# (예: @ -> %40, # -> %23, ! -> %21)
DATABASE_URL=postgresql://postgres.<project-ref>:<url-encoded-password>@aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres

# SOLAPI 문자 발송 (결제 완료 알림). SOLAPI 콘솔 > 개발 > API Key 관리에서 발급
# 주의: API 키에 IP 제한을 걸면 Vercel(유동 IP)에서 발송이 실패함
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
SOLAPI_SENDER=
ADMIN_PHONE=
